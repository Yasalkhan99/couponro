# Copy this file to .env and fill in your values.

# Site
NEXT_PUBLIC_SITE_URL=https://couponro.com

# SMTP (contact form emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@couponro.com
CONTACT_TO_EMAIL=contact@couponro.com

# Admin (optional)
ADMIN_PASSWORD=your-secure-admin-password

# Supabase (if used)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Sanity (blog CMS)
NEXT_PUBLIC_SANITY_PROJECT_ID=vcoir7t9
NEXT_PUBLIC_SANITY_DATASET=production
# Deployed Studio URL (after cd studio && npm run deploy) — /studio page par "Open Studio" isi par jayega
NEXT_PUBLIC_SANITY_STUDIO_URL=
